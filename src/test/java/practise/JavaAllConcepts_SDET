    // ─────────────────────────────────────────────────────────
    // SECTION 19: FUNCTIONAL INTERFACES (Java 8+)
    // ─────────────────────────────────────────────────────────
    // @FunctionalInterface → exactly ONE abstract method
    // Enables lambda expressions
    static void demonstrateFunctionalInterfaces() {
        System.out.println("--- SECTION: FUNCTIONAL INTERFACES ---");

        // Predicate<T>   → takes T, returns boolean → used for filtering
        Predicate<String> isLong = s -> s.length() > 5;
        System.out.println("Predicate isLong('Selenium'): " + isLong.test("Selenium")); // true
        System.out.println("Predicate isLong('Java')    : " + isLong.test("Java"));     // false

        // Predicate chaining
        Predicate<String> startsWithS = s -> s.startsWith("S");
        Predicate<String> combined    = isLong.and(startsWithS);    // AND
        Predicate<String> either      = isLong.or(startsWithS);     // OR
        Predicate<String> notLong     = isLong.negate();            // NOT
        System.out.println("and (Selenium): " + combined.test("Selenium")); // true
        System.out.println("or  (Sam)     : " + either.test("Sam"));        // true
        System.out.println("negate(Java)  : " + notLong.test("Java"));      // true

        // Function<T,R>  → takes T, returns R → transformation/mapping
        Function<String, Integer> strLen = String::length;
        Function<Integer, String> intStr = i -> "Number: " + i;
        System.out.println("Function len  : " + strLen.apply("Selenium")); // 8
        System.out.println("Function andThen: " + strLen.andThen(intStr).apply("Selenium"));

        // Consumer<T>    → takes T, returns nothing → side effects (printing, saving)
        Consumer<String> printer = System.out::println;
        Consumer<String> shouter = s -> System.out.println(s.toUpperCase());
        printer.accept("Consumer: hello");
        printer.andThen(shouter).accept("chained");   // runs both

        // Supplier<T>    → takes nothing, returns T → factory/lazy evaluation
        Supplier<String> greeting = () -> "Hello from Supplier!";
        System.out.println(greeting.get());

        // BiFunction<T,U,R> → takes two inputs, returns one output
        java.util.function.BiFunction<String, Integer, String> repeat =
                (s, n) -> s.repeat(n);
        System.out.println("BiFunction: " + repeat.apply("Ha", 3)); // HaHaHa

        // Custom functional interface (see SDETAction below)
        SDETAction clickAction = (element, timeout) ->
                System.out.println("Clicking " + element + " with timeout " + timeout + "s");
        clickAction.perform("loginButton", 10);

        System.out.println();
    }


    // ─────────────────────────────────────────────────────────
    // SECTION 20: MULTITHREADING
    // ─────────────────────────────────────────────────────────
    // 'synchronized' → only ONE thread can enter at a time
    // 'volatile'     → variable always read from main memory (not cache)
    // 'Thread'       → represents a unit of execution
    // 'Runnable'     → functional interface for thread task
    static void demonstrateMultithreading() {
        System.out.println("--- SECTION: MULTITHREADING ---");

        // Way 1: Extend Thread class
        Thread t1 = new Thread() {
            @Override
            public void run() {
                System.out.println("Thread by extending: " + Thread.currentThread().getName());
            }
        };
        t1.start();  // start() creates new thread; never call run() directly

        // Way 2: Implement Runnable (preferred)
        Runnable task = () -> System.out.println("Runnable thread: " + Thread.currentThread().getName());
        Thread t2 = new Thread(task, "Worker-1");
        t2.start();

        // Wait for threads to finish
        try {
            t1.join();  // main thread waits for t1 to complete
            t2.join();  // main thread waits for t2 to complete
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt(); // restore interrupted status
        }

        // Thread properties
        System.out.println("Main thread: "     + Thread.currentThread().getName());
        System.out.println("Thread priority: " + Thread.currentThread().getPriority()); // 1-10
        System.out.println("Is daemon: "       + Thread.currentThread().isDaemon());

        // Thread states: NEW → RUNNABLE → BLOCKED/WAITING/TIMED_WAITING → TERMINATED
        Thread t3 = new Thread(() -> {});
        System.out.println("Before start: " + t3.getState()); // NEW
        t3.start();
        System.out.println("After start : " + t3.getState()); // RUNNABLE or TERMINATED

        // ExecutorService → thread pool (better than raw threads in production)
        java.util.concurrent.ExecutorService executor =
                java.util.concurrent.Executors.newFixedThreadPool(3);

        for (int i = 1; i <= 3; i++) {
            final int taskNum = i;
            executor.submit(() ->
                    System.out.println("Pool thread executing task " + taskNum + " on " +
                            Thread.currentThread().getName()));
        }
        executor.shutdown(); // no new tasks; waits for running ones to finish

        // synchronized counter example
        Counter counter = new Counter();
        Thread inc1 = new Thread(() -> { for(int i=0;i<100;i++) counter.increment(); });
        Thread inc2 = new Thread(() -> { for(int i=0;i<100;i++) counter.increment(); });
        inc1.start(); inc2.start();
        try { inc1.join(); inc2.join(); } catch (InterruptedException e) { Thread.currentThread().interrupt(); }
        System.out.println("Synchronized counter (expected 200): " + counter.getCount());

        System.out.println();
    }


