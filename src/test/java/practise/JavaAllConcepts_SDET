        // 2D Array (matrix)
        int[][] matrix = {
                {1, 2, 3},
                {4, 5, 6},
                {7, 8, 9}
        };
        System.out.println("matrix[1][2] = " + matrix[1][2]); // row 1, col 2 → 6

        // Array iteration
        System.out.print("Array: ");
        for (int n : nums2) System.out.print(n + " ");
        System.out.println();

        // Sorting
        int[] unsorted = {5, 2, 8, 1, 9, 3};
        Arrays.sort(unsorted);                                  // in-place sort
        System.out.println("Sorted: " + Arrays.toString(unsorted));

        // Copying arrays
        int[] copy = Arrays.copyOf(nums2, nums2.length);
        int[] rangeCopy = Arrays.copyOfRange(nums2, 1, 4);     // index 1 to 3
        System.out.println("Range copy: " + Arrays.toString(rangeCopy)); // [2,3,4]

        // Filling
        int[] filled = new int[5];
        Arrays.fill(filled, 7);
        System.out.println("Filled: " + Arrays.toString(filled));        // [7,7,7,7,7]

        // Array to List (note: fixed-size, not resizable)
        String[] arr = {"a", "b", "c"};
        List<String> list = Arrays.asList(arr);
        System.out.println("Array to List: " + list);

        System.out.println();
    }


