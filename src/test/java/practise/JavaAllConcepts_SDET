    // ─────────────────────────────────────────────────────────
    // SECTION 15: EXCEPTION HANDLING
    // ─────────────────────────────────────────────────────────
    // try     → block that might throw an exception
    // catch   → handles the exception (can have multiple)
    // finally → ALWAYS runs (cleanup: close files, drivers, etc.)
    // throw   → manually throw an exception
    // throws  → declares exceptions a method might throw
    static void demonstrateExceptionHandling() {
        System.out.println("--- SECTION: EXCEPTION HANDLING ---");

        // --- Basic try-catch-finally ---
        try {
            int result = 10 / 0;             // ArithmeticException
            System.out.println(result);
        } catch (ArithmeticException e) {
            System.out.println("Caught: " + e.getMessage()); // / by zero
        } finally {
            System.out.println("finally always runs (e.g., close WebDriver)");
        }

        // --- Multiple catch blocks (most specific first!) ---
        try {
            String s = null;
            s.length();                      // NullPointerException
        } catch (NullPointerException e) {
            System.out.println("Null pointer: " + e.getClass().getSimpleName());
        } catch (Exception e) {              // parent catches rest
            System.out.println("General: " + e.getMessage());
        }

        // --- Multi-catch (Java 7+) → handle multiple types in one catch ---
        try {
            int[] arr = new int[3];
            arr[10] = 5;                     // ArrayIndexOutOfBoundsException
        } catch (ArrayIndexOutOfBoundsException | NullPointerException e) {
            System.out.println("Multi-catch: " + e.getClass().getSimpleName());
        }

        // --- Try-with-resources (Java 7+) → auto-closes Closeable resources ---
        // No need for explicit finally → resource.close()
        try (StringReader reader = new StringReader("test data")) {
            System.out.println("Try-with-resources: auto-closed after block");
        } catch (Exception e) {
            e.printStackTrace();
        }

        // --- throw keyword → manually throw exception ---
        try {
            validateAge(-5);
        } catch (IllegalArgumentException e) {
            System.out.println("Custom throw: " + e.getMessage());
        }

        // --- Custom exception ---
        try {
            throw new TestFailedException("Element not found on page");
        } catch (TestFailedException e) {
            System.out.println("Custom exception: " + e.getMessage());
        }

        // --- Exception hierarchy ---
        // Throwable
        //   ├── Error          (JVM issues: OutOfMemoryError → don't catch these)
        //   └── Exception
        //         ├── Checked Exceptions (must declare or catch: IOException, SQLException)
        //         └── RuntimeException  (unchecked: NullPointer, ArrayIndex, ClassCast)

        System.out.println();
    }

    // Method that declares it throws → caller must handle
    static void validateAge(int age) throws IllegalArgumentException {
        if (age < 0) {
            throw new IllegalArgumentException("Age cannot be negative: " + age);
        }
    }


