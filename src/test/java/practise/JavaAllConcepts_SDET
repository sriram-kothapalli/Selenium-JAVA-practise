    // ─────────────────────────────────────────────────────────
    static void demonstrateOperators() {
        System.out.println("--- SECTION: OPERATORS ---");

        int a = 10, b = 3;

        // Arithmetic operators
        System.out.println("a + b  = " + (a + b));   // Addition       → 13
        System.out.println("a - b  = " + (a - b));   // Subtraction    → 7
        System.out.println("a * b  = " + (a * b));   // Multiplication → 30
        System.out.println("a / b  = " + (a / b));   // Division       → 3 (int division!)
        System.out.println("a % b  = " + (a % b));   // Modulus        → 1 (remainder)

        // Compound assignment
        int x = 5;
        x += 3;   // x = x + 3 → 8
        x -= 1;   // x = x - 1 → 7
        x *= 2;   // x = x * 2 → 14
        x /= 2;   // x = x / 2 → 7
        x %= 3;   // x = x % 3 → 1
        System.out.println("Compound x = " + x);

        // Increment / Decrement
        int i = 5;
        System.out.println("i++  = " + i++); // Post: returns 5, THEN increments
        System.out.println("++i  = " + ++i); // Pre:  increments FIRST, then returns
        System.out.println("i--  = " + i--); // Post: returns 7, THEN decrements
        System.out.println("--i  = " + --i); // Pre:  decrements FIRST, then returns

        // Comparison (Relational) operators → always return boolean
        System.out.println("a == b  : " + (a == b));  // equal
        System.out.println("a != b  : " + (a != b));  // not equal
        System.out.println("a >  b  : " + (a > b));   // greater than
        System.out.println("a <  b  : " + (a < b));   // less than
        System.out.println("a >= b  : " + (a >= b));  // greater or equal
        System.out.println("a <= b  : " + (a <= b));  // less or equal

        // Logical operators
        boolean t = true, f = false;
        System.out.println("t && f  : " + (t && f));  // AND → false
        System.out.println("t || f  : " + (t || f));  // OR  → true
        System.out.println("!t      : " + (!t));       // NOT → false

        // Bitwise operators (rarely in SDET, but good to know)
        System.out.println("5 & 3   : " + (5 & 3));   // Bitwise AND  → 1
        System.out.println("5 | 3   : " + (5 | 3));   // Bitwise OR   → 7
        System.out.println("5 ^ 3   : " + (5 ^ 3));   // Bitwise XOR  → 6
        System.out.println("~5      : " + (~5));        // Bitwise NOT  → -6
        System.out.println("5 << 1  : " + (5 << 1));  // Left shift   → 10
        System.out.println("5 >> 1  : " + (5 >> 1));  // Right shift  → 2

        // Ternary operator → condition ? valueIfTrue : valueIfFalse
        int age = 20;
        String status = (age >= 18) ? "Adult" : "Minor"; // short if-else
        System.out.println("Ternary status: " + status);

        // instanceof keyword → checks if object is instance of a class
        String str = "Hello";
        System.out.println("str instanceof String: " + (str instanceof String)); // true

        System.out.println();
    }


    // ─────────────────────────────────────────────────────────
    // SECTION 9: CONTROL FLOW
    // ─────────────────────────────────────────────────────────
    static void demonstrateControlFlow() {
        System.out.println("--- SECTION: CONTROL FLOW ---");

        // --- IF / ELSE IF / ELSE ---
        // 'if'     → checks a condition
        // 'else if' → another condition if previous was false
        // 'else'   → runs when all conditions are false
        int score = 75;

        if (score >= 90) {
            System.out.println("Grade: A");
        } else if (score >= 75) {
            System.out.println("Grade: B");  // ← this runs
        } else if (score >= 60) {
            System.out.println("Grade: C");
        } else {
            System.out.println("Grade: F");
        }

        // --- SWITCH STATEMENT (traditional) ---
        // 'switch'  → selects one block to run based on value
        // 'case'    → each possible value
        // 'break'   → exits switch (without it, falls through to next case)
        // 'default' → runs if no case matches (like else)
        String browser = "Chrome";

        switch (browser) {
            case "Chrome":
                System.out.println("Using ChromeDriver");
                break;           // ← important: stops here
            case "Firefox":
                System.out.println("Using GeckoDriver");
                break;
            case "Edge":
                System.out.println("Using EdgeDriver");
                break;
            default:
                System.out.println("Unknown browser");
        }

        // --- SWITCH EXPRESSION (Java 14+) → cleaner, no fall-through, returns value ---
        String driver = switch (browser) {
            case "Chrome"  -> "ChromeDriver";   // arrow syntax, no break needed
            case "Firefox" -> "GeckoDriver";
            case "Edge"    -> "EdgeDriver";
            default        -> "Unknown";
        };
        System.out.println("Driver: " + driver);

        // --- SWITCH with yield (multi-line case block) ---
        int retryCount = switch (browser) {
            case "Chrome" -> {
                System.out.println("Chrome selected");
                yield 3;  // 'yield' returns value from block
            }
            default -> 1;
        };
        System.out.println("Retry count: " + retryCount);

        System.out.println();
    }


    // ─────────────────────────────────────────────────────────
    // SECTION 10: LOOPS
    // ─────────────────────────────────────────────────────────
    static void demonstrateLoops() {
        System.out.println("--- SECTION: LOOPS ---");

        // --- FOR LOOP → when number of iterations is known ---
        // init; condition; update
        System.out.print("for loop: ");
        for (int i = 0; i < 5; i++) {
            System.out.print(i + " ");  // 0 1 2 3 4
        }
        System.out.println();

        // --- WHILE LOOP → when condition is checked BEFORE each iteration ---
        System.out.print("while: ");
        int w = 0;
        while (w < 5) {
            System.out.print(w + " ");
            w++;
        }
        System.out.println();

        // --- DO-WHILE → body runs AT LEAST ONCE, condition checked AFTER ---
        System.out.print("do-while: ");
        int d = 0;
        do {
            System.out.print(d + " ");
            d++;
        } while (d < 5);
        System.out.println();

        // --- ENHANCED FOR (for-each) → iterates over array/collection ---
        String[] browsers = {"Chrome", "Firefox", "Edge", "Safari"};
        System.out.print("for-each: ");
        for (String b : browsers) {   // reads as "for each String b in browsers"
            System.out.print(b + " ");
        }
        System.out.println();

        // --- BREAK → exits the loop immediately ---
        System.out.print("break demo: ");
        for (int i = 0; i < 10; i++) {
            if (i == 5) break;        // stops loop when i reaches 5
            System.out.print(i + " ");
        }
        System.out.println();

        // --- CONTINUE → skips current iteration, goes to next ---
        System.out.print("continue demo (skip evens): ");
        for (int i = 0; i < 10; i++) {
            if (i % 2 == 0) continue; // skip even numbers
            System.out.print(i + " ");
        }
        System.out.println();

        // --- LABELED BREAK → exits outer loop from inside inner loop ---
        outer:                        // label marks the outer loop
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                if (i == 1 && j == 1) break outer; // exits both loops
                System.out.print("[" + i + "," + j + "] ");
            }
        }
        System.out.println("\n");
    }


