    static void demonstrateArrays() {
        System.out.println("--- SECTION: ARRAYS ---");

        // Single-dimensional array
        int[] nums = new int[5];          // declares array of 5 ints (default: 0)
        nums[0] = 10;
        nums[1] = 20;
        int[] nums2 = {1, 2, 3, 4, 5};   // array literal shorthand

        System.out.println("Length: " + nums2.length);         // .length (not a method call)
        System.out.println("First : " + nums2[0]);             // index starts at 0
