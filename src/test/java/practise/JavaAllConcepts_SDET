    // ─────────────────────────────────────────────────────────
    // SECTION 13: OOP — OBJECT-ORIENTED PROGRAMMING
    // ─────────────────────────────────────────────────────────
    static void demonstrateOOP() {
        System.out.println("--- SECTION: OOP ---");

        // --- 1. CLASS & OBJECT ---
        // Creating objects with 'new' keyword
        Animal dog = new Animal("Dog", "Buddy", 3);
        dog.speak();
        System.out.println("Name: " + dog.getName() + ", Age: " + dog.getAge());

        // --- 2. INHERITANCE → 'extends' ---
        // Dog inherits from Animal, adds/overrides behavior
        Dog rex = new Dog("Rex", 5);
        rex.speak();       // overridden method (polymorphism)
        rex.fetch();       // Dog-specific method

        // --- 3. POLYMORPHISM → same reference type, different behavior ---
        Animal polyAnimal = new Dog("Poly", 2); // Animal reference → Dog object
        polyAnimal.speak();                      // calls Dog's speak() at runtime
        // polyAnimal.fetch(); ← compile error: Animal doesn't have fetch()

        // --- 4. INTERFACE USAGE ---
        Drivable car = new Car("Tesla", "Model 3");
        car.drive();
        car.stop();

        // --- 5. ABSTRACT CLASS USAGE ---
        Shape circle = new Circle(5.0);
        System.out.println("Circle area: " + circle.calculateArea());
        circle.describe(); // concrete method from abstract class

        // --- 6. THIS keyword → refers to current object ---
        //     SUPER keyword → refers to parent class
        // (shown inside class definitions below)

        // --- 7. INSTANCEOF keyword ---
        System.out.println("rex instanceof Dog   : " + (rex instanceof Dog));    // true
        System.out.println("rex instanceof Animal: " + (rex instanceof Animal)); // true (Dog IS-A Animal)

        // Pattern matching instanceof (Java 16+)
        Object obj = "Hello SDET";
        if (obj instanceof String str2) {    // casts & declares in one step
            System.out.println("Pattern match str length: " + str2.length());
        }

        System.out.println();
    }


    // ─────────────────────────────────────────────────────────
    // SECTION 14: COLLECTIONS FRAMEWORK
    // ─────────────────────────────────────────────────────────
    static void demonstrateCollections() {
        System.out.println("--- SECTION: COLLECTIONS ---");

        // ── ArrayList → ordered, resizable, allows duplicates, null ──
        List<String> arrayList = new ArrayList<>();
        arrayList.add("Chrome");
        arrayList.add("Firefox");
        arrayList.add("Edge");
        arrayList.add("Chrome");           // duplicates allowed
        arrayList.add(1, "Safari");        // insert at index
        System.out.println("ArrayList        : " + arrayList);
        System.out.println("get(0)           : " + arrayList.get(0));
        System.out.println("size()           : " + arrayList.size());
        System.out.println("contains('Edge') : " + arrayList.contains("Edge"));
        arrayList.remove("Safari");        // remove by value
        arrayList.remove(0);               // remove by index
        System.out.println("After removes    : " + arrayList);
        Collections.sort(arrayList);       // sort alphabetically
        System.out.println("Sorted           : " + arrayList);

        // ── LinkedList → doubly-linked list, good for frequent insert/delete ──
        LinkedList<String> linkedList = new LinkedList<>();
        linkedList.add("First");
        linkedList.addFirst("Zero");       // add to front
        linkedList.addLast("Last");        // add to end
        System.out.println("LinkedList       : " + linkedList);
        System.out.println("peek (no remove) : " + linkedList.peek());
        System.out.println("poll (removes)   : " + linkedList.poll());

        // ── Queue → FIFO (First In, First Out) ──
        Queue<String> queue = new LinkedList<>();
        queue.offer("Task1");              // add to queue
        queue.offer("Task2");
        queue.offer("Task3");
        System.out.println("Queue peek: " + queue.peek());   // look at front
        System.out.println("Queue poll: " + queue.poll());   // remove from front
        System.out.println("Queue now : " + queue);

        // ── Stack → LIFO (Last In, First Out) ──
        // Use Deque<String> stack = new ArrayDeque<>() → preferred over Stack class
        Deque<String> stack = new ArrayDeque<>();
        stack.push("Step1");              // push to top
        stack.push("Step2");
        stack.push("Step3");
        System.out.println("Stack peek: " + stack.peek());   // look at top
        System.out.println("Stack pop : " + stack.pop());    // remove from top
        System.out.println("Stack now : " + stack);

        // ── HashSet → unordered, NO duplicates ──
        Set<String> hashSet = new HashSet<>();
        hashSet.add("Selenium");
        hashSet.add("TestNG");
        hashSet.add("Selenium");           // duplicate → ignored
        hashSet.add("JUnit");
        System.out.println("HashSet (no order, no dupes): " + hashSet);

        // ── LinkedHashSet → preserves insertion order, no duplicates ──
        Set<String> linkedSet = new LinkedHashSet<>();
        linkedSet.add("C"); linkedSet.add("A"); linkedSet.add("B");
        System.out.println("LinkedHashSet (ordered): " + linkedSet);

        // ── TreeSet → sorted natural order, no duplicates ──
        Set<Integer> treeSet = new TreeSet<>();
        treeSet.add(5); treeSet.add(1); treeSet.add(3);
        System.out.println("TreeSet (sorted): " + treeSet);

        // ── HashMap → key-value pairs, unordered, one null key ──
