        String[] parts = csv.split(",");
        System.out.println("split result[1]: " + parts[1]); // Firefox

        // Join / concat
        String joined = String.join(" | ", parts);
        System.out.println("join: " + joined);

        // String.format → build dynamic strings (like in assertions)
        String msg = String.format("Test %s on %s browser - Status: %d", "Login", "Chrome", 200);
