    // ─────────────────────────────────────────────────────────
    // SECTION 25: TYPECASTING & WRAPPER CLASSES
    // ─────────────────────────────────────────────────────────
    static void demonstrateTypecastingAndWrappers() {
        System.out.println("--- SECTION: TYPECASTING & WRAPPERS ---");

        // --- Widening (implicit) → smaller to larger, no data loss ---
        int    i   = 100;
        long   l   = i;      // int → long automatically
        double d   = l;      // long → double automatically
        System.out.println("Widening: " + i + " → " + l + " → " + d);

        // --- Narrowing (explicit) → larger to smaller, may lose data ---
        double pi   = 3.14159;
        int    piInt = (int) pi;    // (int) is the cast operator → truncates decimal
        System.out.println("Narrowing: " + pi + " → " + piInt);

        // --- Object casting ---
        Animal a  = new Dog("Buddy", 3);    // upcasting (implicit) - safe always
        Dog    dog = (Dog) a;               // downcasting (explicit) - check first!
        System.out.println("Downcasted: " + dog.getName());

        // Safe downcasting with instanceof
        if (a instanceof Dog d2) {          // pattern matching (Java 16+)
            System.out.println("Safe downcast: " + d2.getName());
        }

        // --- Autoboxing/Unboxing → primitive ↔ wrapper object ---
        // Wrapper classes: Byte, Short, Integer, Long, Float, Double, Character, Boolean
        int primitive    = 42;
        Integer boxed    = primitive;   // autoboxing:   int → Integer
        int unboxed      = boxed;       // unboxing: Integer → int

        System.out.println("Autoboxed : " + boxed);
        System.out.println("Unboxed   : " + unboxed);

        // Wrapper class methods (useful for parsing)
        System.out.println("parseInt    : " + Integer.parseInt("123"));
        System.out.println("parseDouble : " + Double.parseDouble("3.14"));
        System.out.println("MAX_VALUE   : " + Integer.MAX_VALUE);          // 2,147,483,647
        System.out.println("MIN_VALUE   : " + Integer.MIN_VALUE);          // -2,147,483,648
        System.out.println("toBinaryStr : " + Integer.toBinaryString(10)); // 1010
        System.out.println("toHexString : " + Integer.toHexString(255));   // ff
        System.out.println("toString(42): " + Integer.toString(42));
        System.out.println("compare     : " + Integer.compare(5, 10));     // negative (5 < 10)

        // Character wrapper
        System.out.println("isDigit('5')  : " + Character.isDigit('5'));
        System.out.println("isLetter('a') : " + Character.isLetter('a'));
        System.out.println("isUpper('A')  : " + Character.isUpperCase('A'));
        System.out.println("toUpper('a')  : " + Character.toUpperCase('a'));

        System.out.println();
    }


    // ─────────────────────────────────────────────────────────
    // SECTION 26: STATIC vs INSTANCE
    // ─────────────────────────────────────────────────────────
    static void demonstrateStaticAndInstance() {
        System.out.println("--- SECTION: STATIC vs INSTANCE ---");

        // static members → belong to CLASS (shared by all objects)
        System.out.println("Static counter before: " + Counter.getCount());
        Counter c1 = new Counter(); c1.increment();
        Counter c2 = new Counter(); c2.increment(); c2.increment();
        // count is shared → both c1 and c2 increment the SAME counter
        System.out.println("Static counter after : " + Counter.getCount());

        // Instance members → belong to each OBJECT
        Animal a1 = new Animal("Cat", "Whiskers", 2);
        Animal a2 = new Animal("Dog", "Rex", 4);
        System.out.println("Instance a1 name: " + a1.getName()); // Whiskers
        System.out.println("Instance a2 name: " + a2.getName()); // Rex (different objects)

        // Static utility method → called on class, not object
        System.out.println("Static method: " + MathUtils.add(3, 4));

        System.out.println();
    }


    // ─────────────────────────────────────────────────────────
    // SECTION 27: INNER CLASSES
    // ─────────────────────────────────────────────────────────
    static void demonstrateInnerClasses() {
        System.out.println("--- SECTION: INNER CLASSES ---");

        // 1. Non-static inner class → needs outer class instance
        Outer outer = new Outer("Outer data");
        Outer.Inner inner = outer.new Inner();  // note: outer.new
        inner.display();

        // 2. Static nested class → no outer instance needed
        Outer.StaticNested nested = new Outer.StaticNested();
        nested.show();

        // 3. Local class → defined inside a method
        class LocalValidator {
            boolean isValid(String email) { return email.contains("@"); }
        }
        LocalValidator v = new LocalValidator();
        System.out.println("Local class valid: " + v.isValid("test@test.com"));

        System.out.println();
    }


    // ─────────────────────────────────────────────────────────
    // SECTION 28: ANONYMOUS CLASS
    // ─────────────────────────────────────────────────────────
    static void demonstrateAnonymousClass() {
        System.out.println("--- SECTION: ANONYMOUS CLASS ---");

        // Anonymous class → implements interface or extends class
        // inline, one-time use, no name
        Runnable anon = new Runnable() {
            @Override
            public void run() {
                System.out.println("Anonymous Runnable executed!");
            }
        };
        anon.run();

        // Anonymous Comparator (before lambdas existed)
        Comparator<String> lengthComp = new Comparator<String>() {
            @Override
            public int compare(String a, String b) {
                return Integer.compare(a.length(), b.length());
            }
        };
        List<String> words = new ArrayList<>(Arrays.asList("Selenium", "Java", "API"));
        words.sort(lengthComp);
        System.out.println("Anonymous comparator: " + words);

        System.out.println();
    }


    // ─────────────────────────────────────────────────────────
    // SECTION 29: SDET-SPECIFIC PATTERNS
    // ─────────────────────────────────────────────────────────
    static void demonstrateSDETPatterns() {
        System.out.println("--- SECTION: SDET PATTERNS ---");

        // --- Page Object Model pattern (simplified) ---
        LoginPage loginPage = new LoginPage("https://app.example.com");
        loginPage.navigate();
        loginPage.enterCredentials("admin", "password");
        loginPage.clickLogin();

        // --- Builder Pattern → used in test data builders ---
        TestUser user = new TestUser.Builder()
                .username("testuser")
                .password("pass123")
                .email("test@test.com")
                .role("ADMIN")
                .build();
        System.out.println("Builder: " + user);

        // --- Singleton Pattern → used for WebDriver, config ---
        Config config1 = Config.getInstance();
        Config config2 = Config.getInstance();
        System.out.println("Singleton same: " + (config1 == config2)); // true

        // --- Factory Pattern → creating drivers by type ---
        TestEnvironment env = EnvironmentFactory.create("QA");
        System.out.println("Factory env: " + env.getBaseUrl());

        // --- Data-driven test simulation ---
        List<Map<String, String>> testData = getTestData();
        testData.forEach(data -> {
            System.out.println("Running test with: " + data);
        });

        // --- Retry logic (common in flaky test handling) ---
        boolean result = retryOperation(3, () -> {
            System.out.println("  Attempting operation...");
            return true; // simulate success
        });
        System.out.println("Retry result: " + result);

        System.out.println();
    }

    static List<Map<String, String>> getTestData() {
        List<Map<String, String>> data = new ArrayList<>();
        String[][] raw = {
                {"user", "admin",   "pass", "admin123"},
                {"user", "viewer",  "pass", "view123"},
                {"user", "tester",  "pass", "test123"}
        };
        for (String[] row : raw) {
            Map<String, String> map = new LinkedHashMap<>();
            map.put(row[0], row[1]);
            map.put(row[2], row[3]);
            data.add(map);
        }
        return data;
    }

    // Generic retry method using Supplier
    static boolean retryOperation(int maxAttempts, Supplier<Boolean> operation) {
        for (int attempt = 1; attempt <= maxAttempts; attempt++) {
            try {
                if (operation.get()) return true;
            } catch (Exception e) {
                System.out.println("  Attempt " + attempt + " failed: " + e.getMessage());
                if (attempt == maxAttempts) throw e;
            }
        }
        return false;
    }


    // ════════════════════════════════════════════════════════
    //  SUPPORTING CLASSES, INTERFACES, ENUMS (all in one file)
    // ════════════════════════════════════════════════════════


    // ── INTERFACES ─────────────────────────────────────────
    // 'interface' → pure contract: what a class CAN DO (no state)
    // All methods are implicitly public abstract (unless default/static)
    // Java 8+: default and static methods allowed
    interface Drivable {
        void drive();       // abstract → must be implemented
        void stop();        // abstract

        // 'default' → has implementation, can be overridden
        default void honk() {
            System.out.println("Honk honk!");
        }

        // 'static' → belongs to interface, not implementing class
        static Drivable createCar() {
            return new Car("Generic", "Model");
        }
    }

    interface Chargeable {
        void charge();
    }

    // ── ABSTRACT CLASS ─────────────────────────────────────
    // 'abstract class' → partially implemented; cannot instantiate
    // Can have constructors, fields, concrete methods, abstract methods
    abstract static class Shape {
        String color;  // instance field

        Shape(String color) { this.color = color; }  // constructor

        // abstract method → subclass MUST implement
        abstract double calculateArea();

        // concrete method → subclass can use or override
        void describe() {
            System.out.println("I'm a " + color + " " +
                    getClass().getSimpleName() + " with area: " + calculateArea());
        }
    }

    // ── CONCRETE CLASSES ───────────────────────────────────

    // Animal class → demonstrates constructor, this, encapsulation
    static class Animal {
        // Encapsulation: private fields accessed via public getters/setters
        private String species;
        private String name;
        private int    age;

        // Constructor → same name as class, no return type
        Animal(String species, String name, int age) {
            // 'this' → refers to current object's fields
            this.species = species;
            this.name    = name;
            this.age     = age;
        }

        // Getter methods (accessor)
        String getName()    { return name; }
        int    getAge()     { return age;  }
        String getSpecies() { return species; }

        // Setter methods (mutator)
        void setName(String name) { this.name = name; }
        void setAge(int age) {
            if (age < 0) throw new IllegalArgumentException("Age can't be negative");
            this.age = age;
        }

        // Virtual method → can be overridden (polymorphism)
        void speak() {
            System.out.println(name + " says: ...");
        }

        // toString → human-readable representation
        @Override
        public String toString() {
            return "Animal{species='" + species + "', name='" + name + "', age=" + age + "}";
        }
    }

    // Dog extends Animal → Inheritance
    static class Dog extends Animal {
        private String breed;

        Dog(String name, int age) {
            super("Dog", name, age);   // 'super()' calls parent constructor → MUST be first line
            this.breed = "Mixed";
        }

        Dog(String name, int age, String breed) {
            super("Dog", name, age);
            this.breed = breed;
        }

        // @Override → replaces parent's method (polymorphism)
        @Override
        void speak() {
            System.out.println(getName() + " says: Woof! Woof!");
        }

        // Dog-specific method
        void fetch() {
            System.out.println(getName() + " fetches the ball!");
        }

        // Call parent method from child
        void superSpeak() {
            super.speak();   // 'super.' calls parent's version
        }
    }

    // Car → implements multiple interfaces (Java allows this, unlike multiple class inheritance)
    static class Car implements Drivable, Chargeable {
        private String brand;
        private String model;

        Car(String brand, String model) {
            this.brand = brand;
            this.model = model;
        }

        @Override public void drive()  { System.out.println(brand + " " + model + " driving!"); }
        @Override public void stop()   { System.out.println(brand + " " + model + " stopped!"); }
        @Override public void charge() { System.out.println(brand + " " + model + " charging!"); }

        @Override
        public String toString() { return brand + " " + model; }
    }

    // Circle extends Shape → implements abstract method
    static class Circle extends Shape {
        private double radius;

        Circle(double radius) {
            super("red");    // calls Shape constructor
            this.radius = radius;
        }

        @Override
        double calculateArea() {
            return Math.PI * radius * radius;  // Math.PI = 3.14159...
        }
    }

    // ── GENERICS CLASS ─────────────────────────────────────
    static class GenericBox<T> {     // T is type parameter
        private T value;             // T used as field type

        GenericBox(T value) { this.value = value; }  // T in constructor

        T getValue() { return value; }   // T as return type
    }

    // ── ENUM DEFINITIONS ───────────────────────────────────
    enum TestStatus {
        PASSED, FAILED, SKIPPED, PENDING  // constants
    }

    // Enum with fields and methods
    enum Browser {
        CHROME("ChromeDriver", "120"),
        FIREFOX("GeckoDriver", "119"),
        EDGE("EdgeDriver", "119"),
        SAFARI("SafariDriver", "17");

        private final String driver;   // fields in enum
        private final String version;

        Browser(String driver, String version) {  // enum constructor (always private)
            this.driver  = driver;
            this.version = version;
        }

        String getDriver()  { return driver;  }  // methods in enum
        String getVersion() { return version; }
    }

    // ── CUSTOM EXCEPTION ───────────────────────────────────
    // Checked exception → extend Exception
    // Unchecked exception → extend RuntimeException
    static class TestFailedException extends RuntimeException {
        private final String testName;

        TestFailedException(String message) {
            super(message);          // call parent constructor
            this.testName = "Unknown";
        }

        TestFailedException(String testName, String message) {
            super(message);
            this.testName = testName;
        }

        String getTestName() { return testName; }
    }

    // ── SYNCHRONIZED COUNTER ───────────────────────────────
    // 'synchronized' → thread-safe: only one thread runs this method at a time
    static class Counter {
        private static int count = 0;   // static → shared across all instances

        synchronized void increment() {  // only one thread at a time
            count++;
        }

        static int getCount() { return count; }
    }

    // ── INNER / NESTED CLASSES ─────────────────────────────
    static class Outer {
        private String data;

        Outer(String data) { this.data = data; }

        // Non-static inner class → has access to outer class members
        class Inner {
            void display() {
                System.out.println("Inner accessing outer data: " + data); // can access 'data'
            }
        }

        // Static nested class → does NOT have access to outer class members
        static class StaticNested {
            void show() {
                System.out.println("Static nested class (no outer access)");
            }
        }
    }

    // ── FUNCTIONAL INTERFACE ───────────────────────────────
    @FunctionalInterface   // annotation: enforces exactly one abstract method
    interface SDETAction {
        void perform(String element, int timeout);  // only abstract method
        // default and static methods are allowed in functional interface
        default void log() { System.out.println("Action logged"); }
    }

    // ── MATH UTILS (static methods) ────────────────────────
    static class MathUtils {
        // private constructor → prevents instantiation (utility class pattern)
        private MathUtils() {}

        static int    add(int a, int b)           { return a + b; }
        static double power(double base, int exp) { return Math.pow(base, exp); }
        static int    abs(int n)                  { return Math.abs(n); }
    }

    // ── SDET PATTERNS ──────────────────────────────────────

    // Page Object Model
    static class LoginPage {
        private String baseUrl;
        LoginPage(String baseUrl) { this.baseUrl = baseUrl; }
        void navigate()                         { System.out.println("Navigate to: " + baseUrl); }
        void enterCredentials(String u, String p) { System.out.println("Enter creds: " + u + "/" + p); }
        void clickLogin()                       { System.out.println("Click login button"); }
    }

    // Builder Pattern
    static class TestUser {
        private String username, password, email, role;
        private TestUser() {}

        // Builder is a static nested class
        static class Builder {
            private TestUser user = new TestUser();
            Builder username(String v) { user.username = v; return this; }
            Builder password(String v) { user.password = v; return this; }
            Builder email(String v)    { user.email    = v; return this; }
            Builder role(String v)     { user.role     = v; return this; }
            TestUser build()           { return user; }
        }

        @Override
        public String toString() {
            return "TestUser{user=" + username + ", email=" + email + ", role=" + role + "}";
        }
    }

    // Singleton Pattern (thread-safe with double-checked locking)
    static class Config {
        private static volatile Config instance;  // 'volatile' ensures visibility across threads
        private String env = "QA";

        private Config() {}   // private → no direct instantiation

        static Config getInstance() {
            if (instance == null) {                    // first check (no lock)
                synchronized (Config.class) {           // only one thread enters
                    if (instance == null) {             // second check (with lock)
                        instance = new Config();
                    }
                }
            }
            return instance;
        }

        String getEnv() { return env; }
    }

    // Factory Pattern
    interface TestEnvironment {
        String getBaseUrl();
        String getApiKey();
    }

    static class QAEnvironment implements TestEnvironment {
        public String getBaseUrl() { return "https://qa.example.com"; }
        public String getApiKey()  { return "qa-key-123"; }
    }

    static class ProdEnvironment implements TestEnvironment {
        public String getBaseUrl() { return "https://prod.example.com"; }
        public String getApiKey()  { return "prod-key-xyz"; }
    }

    static class EnvironmentFactory {
        static TestEnvironment create(String type) {
            return switch (type.toUpperCase()) {
                case "QA"   -> new QAEnvironment();
                case "PROD" -> new ProdEnvironment();
                default     -> throw new IllegalArgumentException("Unknown env: " + type);
            };
        }
    }

}  // end of class JavaAllConcepts_SDET


// ─────────────────────────────────────────────────────────────
// EXTRA: RECORDS (Java 16+) — immutable data carriers
// ─────────────────────────────────────────────────────────────
// 'record' → auto-generates: constructor, getters, equals, hashCode, toString
// Perfect for: test data, DTOs, API response models
record TestCase(String id, String name, String status) {
    // Compact constructor (for validation)
    TestCase {
        if (id == null || id.isBlank())
            throw new IllegalArgumentException("Test ID cannot be blank");
    }

    // Custom method allowed in records
    boolean isPassed() {
        return "PASSED".equalsIgnoreCase(status);
    }
}


// ─────────────────────────────────────────────────────────────
// EXTRA: SEALED CLASSES (Java 17+)
// ─────────────────────────────────────────────────────────────
// 'sealed' + 'permits' → restricts which classes can extend/implement
// 'non-sealed' → allows further extension
// 'permits' → explicit list of allowed subtypes

sealed class ApiResponse permits SuccessResponse, ErrorResponse {
    protected int statusCode;
    ApiResponse(int statusCode) { this.statusCode = statusCode; }
    int getStatusCode()         { return statusCode; }
}

final class SuccessResponse extends ApiResponse {
    private String body;
    SuccessResponse(String body) { super(200); this.body = body; }
    String getBody() { return body; }
}

final class ErrorResponse extends ApiResponse {
    private String message;
    ErrorResponse(int code, String message) { super(code); this.message = message; }
    String getMessage() { return message; }
}


