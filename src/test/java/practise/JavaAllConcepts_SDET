    // SECTION 17: STREAM API (Java 8+) — KEY FOR SDET
    // ─────────────────────────────────────────────────────────
    static void demonstrateStreamAPI() {
        System.out.println("--- SECTION: STREAM API ---");

        List<String> tests = Arrays.asList(
                "TC001_Login", "TC002_Logout", "TC003_Search",
                "TC004_Login_Negative", "TC005_Checkout"
        );

        // filter()  → keep elements matching predicate
        // map()     → transform each element
        // collect() → gather result into collection
        List<String> loginTests = tests.stream()
                .filter(t -> t.contains("Login"))          // keep only login tests
                .map(String::toUpperCase)                  // transform to uppercase
                .collect(Collectors.toList());             // collect to List
        System.out.println("Login tests   : " + loginTests);

        // forEach() → perform action on each element
        System.out.print("forEach       : ");
        tests.stream().forEach(t -> System.out.print(t + " "));
        System.out.println();

        // count() → count elements
        long count = tests.stream().filter(t -> t.startsWith("TC00")).count();
        System.out.println("count TC00x   : " + count);

        // sorted() → sort elements
        List<String> sorted = tests.stream().sorted().collect(Collectors.toList());
        System.out.println("sorted        : " + sorted);

        // distinct() → remove duplicates
        List<Integer> nums = Arrays.asList(1,2,2,3,3,4);
        List<Integer> distinct = nums.stream().distinct().collect(Collectors.toList());
        System.out.println("distinct      : " + distinct);

        // limit() / skip()
        List<String> limited = tests.stream().limit(3).collect(Collectors.toList());
        System.out.println("limit(3)      : " + limited);
        List<String> skipped = tests.stream().skip(2).collect(Collectors.toList());
        System.out.println("skip(2)       : " + skipped);

        // findFirst() / findAny() → returns Optional
        Optional<String> first = tests.stream().filter(t -> t.contains("Search")).findFirst();
        System.out.println("findFirst     : " + first.orElse("Not found"));

        // anyMatch / allMatch / noneMatch → return boolean
        boolean any  = tests.stream().anyMatch(t -> t.contains("Logout"));
        boolean all  = tests.stream().allMatch(t -> t.startsWith("TC"));
        boolean none = tests.stream().noneMatch(t -> t.contains("Delete"));
        System.out.println("anyMatch(Logout): " + any);
        System.out.println("allMatch(TC)    : " + all);
        System.out.println("noneMatch(Delete): " + none);

        // reduce() → combine all elements into one result
        int sum = Stream.of(1,2,3,4,5).reduce(0, Integer::sum);
        System.out.println("reduce sum    : " + sum);

        // mapToInt / mapToDouble → specialized streams with math operations
        OptionalDouble avg = Stream.of(70, 80, 90, 100)
                .mapToInt(Integer::intValue).average();
        System.out.println("average score : " + avg.getAsDouble());

        // Collectors.joining → concatenate strings
        String joined = tests.stream().collect(Collectors.joining(", "));
        System.out.println("joining       : " + joined);

        // Collectors.groupingBy → group elements by key
        Map<Boolean, List<String>> grouped = tests.stream()
                .collect(Collectors.partitioningBy(t -> t.contains("Login")));
        System.out.println("login group   : " + grouped.get(true));
        System.out.println("other group   : " + grouped.get(false));

        // flatMap() → flatten nested collections
        List<List<String>> nested = Arrays.asList(
                Arrays.asList("a", "b"), Arrays.asList("c", "d")
        );
        List<String> flat = nested.stream()
                .flatMap(Collection::stream)
                .collect(Collectors.toList());
        System.out.println("flatMap       : " + flat);

        System.out.println();
    }


